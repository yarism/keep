{
  "name": "keep",
  "productName": "Keep",
  "version": "1.0.0",
  "description": "A Tower-inspired Git GUI client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac dmg"
  },
  "keywords": [
    "git",
    "gui",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "canvas": "^3.2.3",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.keep.app",
    "productName": "Keep",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": "dmg"
    },
    "files": [
      "main.js",
      "preload.js",
      "git.js",
      "renderer/**/*",
      "assets/icon.png",
      "package.json"
    ]
  }
}
